# ---- Supabase (get these from your Supabase project → Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- AI (required) ----
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ---- Market data ----
# Finnhub (free, 60 calls/min): real-time quotes, macro tape, peers, symbol search
FINNHUB_API_KEY=
# Financial Modeling Prep (free, 250 calls/day): PRIMARY source for real
# financial statements (income/balance/cash-flow, ratios, analyst targets) and
# market movers. Get a key at https://site.financialmodelingprep.com/
FMP_API_KEY=
# FRED (free, unlimited): PRIMARY source for the ECONOMY tape (10Y yield, fed
# funds, CPI inflation, unemployment, WTI). Get a key at
# https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# Alpha Vantage (free, 25 calls/day): FALLBACK for statements/movers/economy
# when FMP/FRED are absent. One deep dive = ~6 calls, cached 7d.
ALPHAVANTAGE_API_KEY=

# ---- Demo mode (optional) ----
# DEMO_MODE=true runs the entire terminal with NO keys and NO Supabase:
# auth bypassed, in-memory state, canned data badged "DEMO". Never in production.
DEMO_MODE=false
