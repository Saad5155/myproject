# ---- Supabase (get these from your Supabase project → Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- AI (required) ----
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ---- Market data ----
# Finnhub (free, 60 calls/min): real-time quotes, macro tape, peers, symbol search
FINNHUB_API_KEY=
# Financial Modeling Prep (free, 250 calls/day): PRIMARY source for real
# financial statements (income/balance/cash-flow, ratios, analyst targets) and
# market movers. Get a key at https://site.financialmodelingprep.com/
FMP_API_KEY=
# FRED (free, unlimited): PRIMARY source for the ECONOMY tape (10Y yield, fed
# funds, CPI inflation, unemployment, WTI). Get a key at
# https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# Alpha Vantage (free, 25 calls/day): FALLBACK for statements/movers/economy
# when FMP/FRED are absent. One deep dive = ~6 calls, cached 7d.
ALPHAVANTAGE_API_KEY=

# ---- Telegram push notifications (optional, PER-USER) ----
# Each user links their own phone: they DM the bot the email their account was
# created with, and their price alerts route to their own Telegram chat.
# Setup (once):
#   1) In Telegram, message @BotFather → /newbot → copy the token + bot username.
#   2) Set the two vars below + CRON_SECRET, then deploy.
#   3) Hit  https://YOUR-URL/api/telegram/setup?secret=YOUR_CRON_SECRET  once to
#      register the webhook. Done — users can now self-link from Settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=        # without the @, e.g. MyTerminalBot
# Secret guarding the alert cron AND used as the Telegram webhook token. Any
# long random string. Vercel Cron sends it automatically; external pingers
# (cron-job.org) call /api/cron/alerts?secret=THIS for intraday checks.
CRON_SECRET=
# Optional: force the public origin used when registering the webhook (defaults
# to the request's own origin, which is correct on Vercel).
NEXT_PUBLIC_SITE_URL=

# ---- Email notifications (optional) ----
# Sign-in alerts + price alerts are emailed to each user's account address,
# using a branded template. Configure EITHER SMTP (any mail server) OR Resend.
# SMTP takes priority if both are set. MAIL_FROM is required for either.
MAIL_FROM=                     # e.g. "Terminal X <alerts@yourdomain.com>"
# -- SMTP (works with Gmail, your own server, etc.) --
SMTP_HOST=                     # e.g. smtp.gmail.com
SMTP_PORT=587                  # 587 (STARTTLS) or 465 (implicit TLS)
SMTP_USER=
SMTP_PASS=
# -- Resend (HTTP API alternative, https://resend.com) --
RESEND_API_KEY=

# ---- Demo mode (optional) ----
# DEMO_MODE=true runs the entire terminal with NO keys and NO Supabase:
# auth bypassed, in-memory state, canned data badged "DEMO". Never in production.
DEMO_MODE=false
