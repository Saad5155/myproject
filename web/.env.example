# ---- Supabase (get these from your Supabase project → Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- AI (required) ----
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ---- Market data ----
# Finnhub (free, 60 calls/min): real-time quotes, macro tape, peers
FINNHUB_API_KEY=
# Alpha Vantage (free, 25 calls/day): REAL financial statements for the deep dive
# (income statement, balance sheet, cash flow, EPS, analyst counts). One deep
# dive = 6 calls, cached 24h → ~4 fresh tickers/day on the free tier.
ALPHAVANTAGE_API_KEY=

# ---- Demo mode (optional) ----
# DEMO_MODE=true runs the entire terminal with NO keys and NO Supabase:
# auth bypassed, in-memory state, canned data badged "DEMO". Never in production.
DEMO_MODE=false
